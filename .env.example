# Firebase Web App configuration
# Create a Firebase project, enable Firestore, Storage, and Email/Password auth,
# then copy these values from Project settings > General > Your apps.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# One-time migration credentials for scripts/migrate-firebase.ts
# Prefer FIREBASE_SERVICE_ACCOUNT_PATH pointing to a local JSON key file.
# You can also provide the full JSON as FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=""
FIREBASE_SERVICE_ACCOUNT_JSON=""

# One-time admin bootstrap values for scripts/bootstrap-admin.ts
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_DISPLAY_NAME="Portfolio Admin"
